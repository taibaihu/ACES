# ===== OKX 交易所 API（真实模式需要；模拟模式留空即可）=====
# 注意：务必使用「只读 + 交易」权限的 API Key，并开启 Passphrase
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# ===== 交易对 / 周期（也可用 CLI 参数覆盖）=====
SYMBOL=BTC-USDT
TIMEFRAME=5m
AUX_TIMEFRAME=15m
MACRO_TIMEFRAME_4H=4h
MACRO_TIMEFRAME_1D=1d

# ===== 仓位 / 风控 =====
LEVERAGE=100
SINGLE_TRADE_SIZE=0.001
STOP_LOSS_ATR_MULT=1.5
MIN_RR_RATIO=2.0

# ===== Gatekeeper 波动率阈值 =====
GATEKEEPER_ATR_MIN=100
GATEKEEPER_SWING_MIN=150

# ===== LLM（三选一，填入对应 Key）=====
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=
